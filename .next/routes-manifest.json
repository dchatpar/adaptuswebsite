  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/home",
      "destination": "/",
      "statusCode": 308,
      "regex": "^(?!/_next)/home(?:/)?$"
    },
    {
      "source": "/services/crm",
      "destination": "/services/crm-automation",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/crm(?:/)?$"
    },
    {
      "source": "/services/msp",
