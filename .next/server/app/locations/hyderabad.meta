{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/locations/layout,_N_T_/locations/[slug]/layout,_N_T_/locations/[slug]/page,_N_T_/locations/hyderabad"
  },
  "segmentPaths": [
